// Short-circuit evaluation: the skipped branches would panic if evaluated.

fn should_not_run() -> bool {
    return panic("short-circuit failed")
}

fn returns_false() -> bool {
    return false
}

entry main() {
    if false && should_not_run() {
        return 1
    }

    if true || should_not_run() {
        assert(true)
    }

    if returns_false() || true {
        return 0
    }

    return 1
}
