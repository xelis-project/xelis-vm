// Closures: typed closure values, inferred closure return types, and callbacks.

fn apply(value: u64, f: closure(u64) -> u64) -> u64 {
    return f(value)
}

entry main() {
    let double: closure(u64) -> u64 = |x: u64| -> u64 {
        return x * 2u64
    }

    let add_one = |x: u64| {
        return x + 1u64
    }

    assert(apply(10u64, double) == 20u64)
    assert(apply(10u64, add_one) == 11u64)

    return 0
}
